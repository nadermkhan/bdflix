<Page
    x:Class="BDFlix.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBgBrush}">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                MaxWidth="400">

        <!-- App icon placeholder -->
        <Border Width="80" Height="80"
                CornerRadius="20"
                Background="{StaticResource PrimaryBrush}"
                HorizontalAlignment="Center">
            <TextBlock Text="BD"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="BDFlix"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Multi-threaded File Browser &amp; Downloader"
                   Foreground="{StaticResource Text2Brush}"
                   FontSize="14"
                   TextAlignment="Center"
                   TextWrapping="Wrap"/>

        <TextBlock Text="Version 3.0 — WinUI 3"
                   Foreground="{StaticResource Text3Brush}"
                   FontSize="12"
                   HorizontalAlignment="Center"/>

        <Rectangle Height="1"
                   Fill="{StaticResource CardHoverBrush}"
                   Margin="0,8"/>

        <!-- Feature highlights -->
        <StackPanel Spacing="8"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="12"
                    Padding="20,16">

            <TextBlock Text="✦  8-thread parallel downloading"
                       Foreground="{StaticResource Text2Brush}"
                       FontSize="13"/>

            <TextBlock Text="✦  Search across 5 servers simultaneously"
                       Foreground="{StaticResource Text2Brush}"
                       FontSize="13"/>

            <TextBlock Text="✦  Pause, resume and queue management"
                       Foreground="{StaticResource Text2Brush}"
                       FontSize="13"/>

            <TextBlock Text="✦  IDM integration"
                       Foreground="{StaticResource Text2Brush}"
                       FontSize="13"/>

            <TextBlock Text="✦  M3U8 playlist export"
                       Foreground="{StaticResource Text2Brush}"
                       FontSize="13"/>
        </StackPanel>

        <!-- Facebook button -->
        <Button Content="Connect on Facebook"
                Click="FbButton_Click"
                Background="#FF1877F2"
                Foreground="White"
                CornerRadius="12"
                Padding="24,12"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>

        <TextBlock Text="© 2024 Nader Mahbub Khan"
                   Foreground="{StaticResource Text3Brush}"
                   FontSize="11"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</Page>
