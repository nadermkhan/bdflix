<Page
    x:Class="BDFlix.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BDFlix"
    Background="{StaticResource AppBgBrush}">

    <Page.Resources>

        <!-- File card item template -->
        <DataTemplate x:Key="FileItemTemplate"
                      x:DataType="local:FileResultVM">
            <Grid Margin="12,2"
                  Background="{StaticResource CardBrush}"
                  CornerRadius="12"
                  Height="68"
                  Padding="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- File type icon -->
                <Border Grid.Column="0"
                        Width="40" Height="40"
                        CornerRadius="10"
                        Background="{x:Bind TypeColor}"
                        VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ExtLabel}"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- File info -->
                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock Text="{x:Bind Name}"
                               Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                    <TextBlock Foreground="{StaticResource Text3Brush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1">
                        <Run Text="{x:Bind Server}"/>
                        <Run Text="  •  "/>
                        <Run Text="{x:Bind Folder}"/>
                    </TextBlock>
                </StackPanel>

                <!-- File size -->
                <TextBlock Grid.Column="2"
                           Text="{x:Bind SizeText}"
                           Foreground="{StaticResource Text2Brush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- ListViewItem override: transparent background -->
        <Style TargetType="ListViewItem"
               x:Key="TransparentListViewItem">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Search box -->
            <RowDefinition Height="Auto"/>  <!-- Filter/sort bar -->
            <RowDefinition Height="*"/>     <!-- Results -->
        </Grid.RowDefinitions>

        <!-- ── Search box ── -->
        <Grid Grid.Row="0"
              Margin="16,8"
              ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Search files... (Enter or click Search)"
                     Background="{StaticResource CardBrush}"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="13"
                     CornerRadius="10"
                     BorderThickness="0"
                     KeyDown="SearchBox_KeyDown"/>

            <Button Grid.Column="1"
                    Content="Search"
                    Click="SearchButton_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    CornerRadius="10"
                    Padding="20,8"/>
        </Grid>

        <!-- ── Sort / filter bar ── -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="16,0,16,8"
                    Spacing="8">
            <TextBlock Text="Sort:"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="11"
                       VerticalAlignment="Center"/>

            <Button x:Name="SortNameBtn"
                    Content="Name ↕"
                    Click="SortName_Click"
                    FontSize="11"
                    Padding="10,4"
                    CornerRadius="8"
                    Background="{StaticResource CardBrush}"
                    Foreground="{StaticResource Text2Brush}"/>

            <Button x:Name="SortSizeBtn"
                    Content="Size ↕"
                    Click="SortSize_Click"
                    FontSize="11"
                    Padding="10,4"
                    CornerRadius="8"
                    Background="{StaticResource CardBrush}"
                    Foreground="{StaticResource Text2Brush}"/>

            <Button x:Name="SortServerBtn"
                    Content="Server ↕"
                    Click="SortServer_Click"
                    FontSize="11"
                    Padding="10,4"
                    CornerRadius="8"
                    Background="{StaticResource CardBrush}"
                    Foreground="{StaticResource Text2Brush}"/>

            <!-- Result count -->
            <TextBlock x:Name="ResultCount"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </StackPanel>

        <!-- ── Results list ── -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <TextBlock x:Name="EmptyState"
                       Text="Search for files to get started"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,80,0,0"/>

            <!-- Searching indicator -->
            <ProgressRing x:Name="SearchProgress"
                          IsActive="False"
                          Width="32" Height="32"
                          Foreground="{StaticResource PrimaryBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0,0,0,60"
                          Visibility="Collapsed"/>

            <ListView x:Name="ResultsList"
                      ItemTemplate="{StaticResource FileItemTemplate}"
                      ItemContainerStyle="{StaticResource TransparentListViewItem}"
                      SelectionMode="Extended"
                      Background="Transparent"
                      DoubleTapped="ResultsList_DoubleTapped"
                      RightTapped="ResultsList_RightTapped"
                      Padding="0,0,0,8">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Grid>
    </Grid>

    <!-- Context menu (defined as flyout on page, shown programmatically) -->
    <Page.ContextFlyout>
        <MenuFlyout x:Name="FileContextMenu">
            <MenuFlyoutItem Text="Download"
                            Click="CtxDownload_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE896;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Download with IDM"
                            Click="CtxIDM_Click"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Text="Copy URL"
                            Click="CtxCopyUrl_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8C8;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Copy Filename"
                            Click="CtxCopyName_Click"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Text="Playlist from Folder"
                            Click="CtxPlaylist_Click"/>
        </MenuFlyout>
    </Page.ContextFlyout>
</Page>
