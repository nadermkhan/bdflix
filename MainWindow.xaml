<Window
    x:Class="BDFlix.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BDFlix"
    Title="BDFlix">

    <Grid Background="{StaticResource AppBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tab bar -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══ Tab bar ══ -->
        <Grid Grid.Row="0"
              Background="#FF121212"
              Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Search tab -->
            <Button x:Name="TabSearch"
                    Grid.Column="0"
                    Content="Search"
                    Click="TabSearch_Click"
                    Style="{StaticResource TabButtonStyle}"/>

            <!-- Downloads tab -->
            <Button x:Name="TabDownloads"
                    Grid.Column="1"
                    Content="Downloads"
                    Click="TabDownloads_Click"
                    Style="{StaticResource TabButtonStyle}"/>

            <!-- About tab -->
            <Button x:Name="TabAbout"
                    Grid.Column="2"
                    Content="About"
                    Click="TabAbout_Click"
                    Style="{StaticResource TabButtonStyle}"/>

            <!-- Active indicator line drawn by code-behind -->
            <Border x:Name="TabIndicator"
                    Grid.Column="0"
                    Height="3"
                    Width="30"
                    CornerRadius="2"
                    Background="{StaticResource PrimaryBrush}"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"/>
        </Grid>

        <!-- ══ Page content (NavigationView-less approach) ══ -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Background="Transparent"/>

        <!-- ══ Status bar ══ -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                BorderBrush="#FF2C2C2E"
                BorderThickness="0,1,0,0"
                Height="24"
                Padding="16,0">
            <TextBlock x:Name="StatusText"
                       Text=" Ready"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
