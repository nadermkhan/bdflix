<Application
    x:Class="BDFlix.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Colors -->
            <Color x:Key="AppBgColor">#FF000000</Color>
            <Color x:Key="CardColor">#FF1C1C1E</Color>
            <Color x:Key="CardHoverColor">#FF2C2C2E</Color>
            <Color x:Key="PrimaryColor">#FF0A84FF</Color>
            <Color x:Key="TextColor">#FFFFFFFF</Color>
            <Color x:Key="Text2Color">#FF989899</Color>
            <Color x:Key="Text3Color">#FF636366</Color>
            <Color x:Key="GreenColor">#FF30D158</Color>
            <Color x:Key="RedColor">#FFFF453A</Color>
            <Color x:Key="OrangeColor">#FFFF9F0A</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}"/>
            <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
            <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHoverColor}"/>
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
            <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}"/>
            <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}"/>
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
            <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
            <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>

            <!-- Video/Audio/Archive type colors -->
            <SolidColorBrush x:Key="VideoBrush" Color="#FFFF375F"/>
            <SolidColorBrush x:Key="AudioBrush" Color="#FFFF9500"/>
            <SolidColorBrush x:Key="ArchiveBrush" Color="#FFAF52DE"/>
            <SolidColorBrush x:Key="DocumentBrush" Color="#FF0A84FF"/>
            <SolidColorBrush x:Key="ExecutableBrush" Color="#FF30D158"/>
            <SolidColorBrush x:Key="DefaultFTBrush" Color="#FF8E8E93"/>

            <!-- Override NavigationView background -->
            <StaticResource x:Key="NavigationViewContentBackground" ResourceKey="AppBgBrush"/>

            <!-- Card style -->
            <Style x:Key="FileCardStyle" TargetType="Grid">
                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="12,2"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
